{
  "parser-directories": [
    "./grammars"
  ],
  "theme": {
    "variable.parameter": {
      "underline": true
    },
    "variable.builtin": {
      "color": "#f38ba9"
    },
    "comment": {
      "color": "#9399b3",
      "italic": true
    },
    "constructor": 136,
    "keyword": { 
      "bold": true,
      "color": "#cba6f8"
    },
    "number": {
      "bold": true,
      "color": "#fab388"
    },
    "punctuation.delimiter": "#9399b3",
    "property":  "#89dcec",
    "operator": {
      "bold": true,
      "color": "#89dcec"
    },
    "function": {
      "bold": true,
      "color": "#89b4fb"
    },
    "type": "#f9e2b0",
    "punctuation.bracket": "#9399b3",
    "string": "#a6e3a2",
    "string.special": "#f5c2e8",
    "constant": "#fab388",
    "tag": "#89b4fb",
    "embedded": null,
    "type.builtin": {
      "bold": true,
      "color": "#cba6f8"
    },
    "module": {
      "bold": true,
      "color": "#f5c2e8"
    }
  }
}
